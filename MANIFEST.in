# MANIFEST.in for GeoPrior-v3

# ---------------------------------------------------------
# Essential root files
# ---------------------------------------------------------
include LICENSE
include README.md
include pyproject.toml
include MANIFEST.in
include setup.py

# ---------------------------------------------------------
# Documentation source (hand-written only)
# ---------------------------------------------------------
recursive-include docs/source *.rst
recursive-include docs/source *.md
recursive-include docs/source *.py
recursive-include docs/source/_templates *
recursive-include docs/source/_static *.css *.js *.svg *.png *.jpg *.jpeg *.ico *.gif

include docs/Makefile
include docs/make.bat
include docs/requirements.txt

# ---------------------------------------------------------
# Exclude generated / heavy / preview docs assets
# ---------------------------------------------------------
prune docs/_build
prune docs/source/_generated
prune docs/source/generated
prune docs/source/_autosummary
prune docs/source/api/_autosummary
prune docs/source/images
prune docs/source/_static/previews
prune docs/source/_static/apps

recursive-exclude docs/source/_generated *
recursive-exclude docs/source/generated *
recursive-exclude docs/source/_autosummary *
recursive-exclude docs/source/api/_autosummary *
recursive-exclude docs/source/images *
recursive-exclude docs/source/_static/previews *

# Never ship Illustrator sources
recursive-exclude docs/source/_static *.ai
global-exclude *.ai

# Optional: common generated doc artefacts
recursive-exclude docs/source *.doctree
recursive-exclude docs/source *.pickle
recursive-exclude docs/source *.ipynb_checkpoints *

# ---------------------------------------------------------
# Package data
# ---------------------------------------------------------
include geoprior/datasets/data/min_zhongshan.csv
recursive-include geoprior/resources *.py *.json *.yaml
recursive-include geoprior/resources *.yml *.txt

# ---------------------------------------------------------
# Compatibility scripts package
# ---------------------------------------------------------
recursive-include scripts *.py

# Keep legacy artifact folders out of source releases
prune scripts/fig
prune scripts/out
recursive-exclude scripts/fig *
recursive-exclude scripts/out *

# ---------------------------------------------------------
# Optional examples
# ---------------------------------------------------------
# recursive-include examples *.py *.ipynb *.csv *.md

# ---------------------------------------------------------
# Exclusions: caches, binaries, build artifacts
# ---------------------------------------------------------
global-exclude *.py[cod]
global-exclude __pycache__/*
global-exclude *.so
global-exclude *.dylib
global-exclude *.o
global-exclude *.a
global-exclude *.dll
global-exclude *.lib

# ---------------------------------------------------------
# Exclude tests and coverage artifacts
# ---------------------------------------------------------
recursive-exclude tests *
exclude .coverage
exclude coverage.xml
exclude .pytest_cache

# ---------------------------------------------------------
# Exclude development / CI files
# ---------------------------------------------------------
exclude .gitignore
exclude .gitattributes
recursive-exclude .github *

# ---------------------------------------------------------
# Exclude local environments
# ---------------------------------------------------------
recursive-exclude venv *
recursive-exclude .venv *

# ---------------------------------------------------------
# Exclude hidden files / dirs and build outputs
# ---------------------------------------------------------
recursive-exclude .* *
recursive-exclude build *
recursive-exclude dist *
recursive-exclude *.egg-info *

# ---------------------------------------------------------
# Optional paper artefacts
# ---------------------------------------------------------
# exclude paper.md
# exclude paper.bib