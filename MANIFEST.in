# MANIFEST.in for GeoPrior-v3 project

# ---------------------------------------------------------
# Essential root files
# ---------------------------------------------------------
include LICENSE
include README.md
include pyproject.toml
include MANIFEST.in
include setup.py

# ---------------------------------------------------------
# PyPI / long-description assets
# ---------------------------------------------------------
recursive-include docs/source/_static *
recursive-include docs/source *.rst
recursive-include docs/source *.py
recursive-include docs/source/_templates *

# Exclude docs images unless explicitly needed
recursive-exclude docs/source/images *

include docs/Makefile
include docs/make.bat
include docs/requirements.txt

# ---------------------------------------------------------
# Package data
# ---------------------------------------------------------
include geoprior/datasets/data/min_zhongshan.csv
recursive-include geoprior/resources *.py *.json *.yaml
recursive-include geoprior/resources *.yml *.txt

# ---------------------------------------------------------
# Compatibility scripts package
# ---------------------------------------------------------
recursive-include scripts *.py

# Keep legacy artifact folders out of source releases
recursive-exclude scripts/fig *
recursive-exclude scripts/out *

# ---------------------------------------------------------
# Optional examples
# ---------------------------------------------------------
# recursive-include examples *.py *.ipynb *.csv *.md

# ---------------------------------------------------------
# Exclusions: caches, binaries, build artifacts
# ---------------------------------------------------------
global-exclude *.py[cod]
global-exclude __pycache__/*
global-exclude *.so
global-exclude *.dylib
global-exclude *.o
global-exclude *.a
global-exclude *.dll
global-exclude *.lib

# ---------------------------------------------------------
# Exclude tests and coverage artifacts
# ---------------------------------------------------------
recursive-exclude tests *
exclude .coverage
exclude coverage.xml
exclude .pytest_cache

# ---------------------------------------------------------
# Exclude development / CI files
# ---------------------------------------------------------
exclude .gitignore
exclude .gitattributes
recursive-exclude .github *

# ---------------------------------------------------------
# Exclude local environments
# ---------------------------------------------------------
recursive-exclude venv *
recursive-exclude .venv *

# ---------------------------------------------------------
# Exclude hidden files / dirs and build outputs
# ---------------------------------------------------------
recursive-exclude .* *
recursive-exclude build *
recursive-exclude dist *
recursive-exclude *.egg-info *
recursive-exclude docs/_build *

# ---------------------------------------------------------
# Prune empty or generated directories
# ---------------------------------------------------------
prune docs/_build
prune scripts/fig
prune scripts/out

# ---------------------------------------------------------
# Optional paper artefacts
# ---------------------------------------------------------
# exclude paper.md
# exclude paper.bib